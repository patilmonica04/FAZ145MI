<?xml version="1.0" encoding="UTF-8"?>
<!--
  Transaction : GetDisposal
  Program     : FAZ145MI
  Description : Retrieve the full details of a single fixed-asset
                disposal record identified by Company / Asset ID /
                Sub-number.

  Business Rules
  ──────────────
  1. The combination of CONO + ASID + SBNO forms the unique key for
     the FFASLT (Fixed Asset Disposal Line) table.
  2. If CONO is omitted the user's current company is used.
  3. Returns error WF02001 when the record does not exist.
-->
<Transaction
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../schema/Transaction.xsd"
    program="FAZ145MI"
    name="GetDisposal"
    description="Get details of a specific fixed-asset disposal"
    type="Get">

  <!-- ── Input ──────────────────────────────────────────────────── -->
  <InputParameters>
    <Parameter field="CONO" description="Company Number"
        type="Numeric" length="3" mandatory="false"
        remarks="Defaults to the user's current company when blank."/>
    <Parameter field="ASID" description="Fixed Asset ID"
        type="String" length="10" mandatory="true"
        remarks="Key field – must match FFASLT.ASID."/>
    <Parameter field="SBNO" description="Sub-number"
        type="Numeric" length="3" mandatory="true"
        remarks="Key field – must match FFASLT.SBNO."/>
  </InputParameters>

  <!-- ── Output ─────────────────────────────────────────────────── -->
  <OutputParameters>
    <Parameter field="CONO" description="Company Number"       type="Numeric" length="3"/>
    <Parameter field="ASID" description="Fixed Asset ID"       type="String"  length="10"/>
    <Parameter field="SBNO" description="Sub-number"           type="Numeric" length="3"/>
    <Parameter field="DISP" description="Disposal Date"        type="Numeric" length="8"
        remarks="Format YYYYMMDD."/>
    <Parameter field="DSCD" description="Disposal Code"        type="String"  length="2"/>
    <Parameter field="DIPR" description="Disposal Proceeds"    type="Numeric" length="17"/>
    <Parameter field="DICU" description="Disposal Currency"    type="String"  length="3"/>
    <Parameter field="DIEX" description="Exchange Rate"        type="Numeric" length="13"/>
    <Parameter field="ANOT" description="Notes / Remark"       type="String"  length="60"/>
    <Parameter field="RESP" description="Responsible Employee" type="String"  length="10"/>
    <Parameter field="DEPT" description="Department"           type="String"  length="8"/>
    <Parameter field="STAT" description="Status"               type="String"  length="2"
        remarks="20 = Pending; 60 = Disposed/Posted; 90 = Reversed."/>
    <Parameter field="RGDT" description="Entry Date"           type="Numeric" length="8"
        remarks="Date the record was created. Format YYYYMMDD."/>
    <Parameter field="RGTM" description="Entry Time"           type="Numeric" length="6"
        remarks="Time the record was created. Format HHMMSS."/>
    <Parameter field="CHID" description="Changed By"           type="String"  length="10"
        remarks="User ID of the last person to update the record."/>
    <Parameter field="LMDT" description="Change Date"          type="Numeric" length="8"
        remarks="Date of the last update. Format YYYYMMDD."/>
  </OutputParameters>

  <!-- ── Error Codes ────────────────────────────────────────────── -->
  <ErrorCodes>
    <ErrorCode code="WF02001" description="No disposal record found for {ASID}/{SBNO} in company {CONO}."/>
  </ErrorCodes>

</Transaction>
