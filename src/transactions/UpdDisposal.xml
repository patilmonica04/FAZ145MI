<?xml version="1.0" encoding="UTF-8"?>
<!--
  Transaction : UpdDisposal
  Program     : FAZ145MI
  Description : Update selected fields of an existing fixed-asset
                disposal record.  Only fields provided in the request
                are changed; omitted fields retain their current values.

  Business Rules
  ──────────────
  1. The record identified by CONO + ASID + SBNO must exist in FFASLT.
  2. Records with status 60 (Disposed/Posted) or 90 (Reversed) cannot
     be updated; they must first be reversed via the Reversal function.
  3. DISP, if supplied, must fall within an open FA period.
  4. DSCD, if supplied, must exist in CSYTAB type "DSCD".
  5. DICU, if supplied, must exist in CSYTAB type "CUCD".
  6. DIPR must be >= 0 when supplied.
  7. CHID and LMDT are updated automatically by the system.
-->
<Transaction
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../schema/Transaction.xsd"
    program="FAZ145MI"
    name="UpdDisposal"
    description="Update an existing fixed-asset disposal record"
    type="Change">

  <!-- ── Input ──────────────────────────────────────────────────── -->
  <InputParameters>
    <Parameter field="CONO" description="Company Number"
        type="Numeric" length="3" mandatory="false"
        remarks="Defaults to the user's current company when blank."/>
    <Parameter field="ASID" description="Fixed Asset ID"
        type="String" length="10" mandatory="true"
        remarks="Key field – identifies the fixed asset."/>
    <Parameter field="SBNO" description="Sub-number"
        type="Numeric" length="3" mandatory="true"
        remarks="Key field – identifies the sub-asset."/>
    <Parameter field="DISP" description="Disposal Date (YYYYMMDD)"
        type="Numeric" length="8" mandatory="false"
        remarks="New disposal date. Must be in an open FA period."/>
    <Parameter field="DSCD" description="Disposal Code"
        type="String" length="2" mandatory="false"
        remarks="New disposal code. Must exist in CSYTAB/DSCD."/>
    <Parameter field="DIPR" description="Disposal Proceeds"
        type="Numeric" length="17" mandatory="false"
        remarks="Updated net proceeds. Must be >= 0."/>
    <Parameter field="DICU" description="Disposal Currency"
        type="String" length="3" mandatory="false"
        remarks="ISO 4217 currency code."/>
    <Parameter field="DIEX" description="Exchange Rate"
        type="Numeric" length="13" mandatory="false"
        remarks="Rate against company base currency."/>
    <Parameter field="ANOT" description="Notes / Remark"
        type="String" length="60" mandatory="false"
        remarks="Free-text description; replaces existing value."/>
    <Parameter field="RESP" description="Responsible Employee"
        type="String" length="10" mandatory="false"
        remarks="Employee ID from CMNPRS."/>
    <Parameter field="DEPT" description="Department"
        type="String" length="8" mandatory="false"
        remarks="Department code from MNDEPT."/>
  </InputParameters>

  <!-- ── Output ─────────────────────────────────────────────────── -->
  <OutputParameters>
    <Parameter field="CONO" description="Company Number"  type="Numeric" length="3"/>
    <Parameter field="ASID" description="Fixed Asset ID"  type="String"  length="10"/>
    <Parameter field="SBNO" description="Sub-number"      type="Numeric" length="3"/>
    <Parameter field="STAT" description="Status"          type="String"  length="2"/>
    <Parameter field="LMDT" description="Change Date"     type="Numeric" length="8"
        remarks="System-generated date of this update. Format YYYYMMDD."/>
  </OutputParameters>

  <!-- ── Error Codes ────────────────────────────────────────────── -->
  <ErrorCodes>
    <ErrorCode code="WF04001" description="No disposal record found for {ASID}/{SBNO} in company {CONO}."/>
    <ErrorCode code="WF04002" description="Disposal record {ASID}/{SBNO} has status {STAT} and cannot be updated."/>
    <ErrorCode code="WF04003" description="Disposal Code {DSCD} is invalid."/>
    <ErrorCode code="WF04004" description="Disposal Date {DISP} is outside an open FA period."/>
    <ErrorCode code="WF04005" description="Currency {DICU} is not defined in the system."/>
    <ErrorCode code="WF04006" description="Disposal Proceeds must be greater than or equal to zero."/>
  </ErrorCodes>

</Transaction>
